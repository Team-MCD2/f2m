# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/connexion
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/admin
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/admin

# Supabase — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Storage Supabase — créer le bucket "candidat-documents" (public) dans le dashboard
SUPABASE_STORAGE_BUCKET=candidat-documents

# Cloudinary (optionnel — images et non-PDF ; les PDF passent par Supabase)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Emails (relances, acceptation, refus, mot de passe) — Nodemailer + Gmail
EMAIL_USER=votre@gmail.com
EMAIL_PASS=mot_de_passe_application_gmail
EMAIL_FROM=F2M Consulting <votre@gmail.com>

# URL publique de l'app (liens dans les emails : activation, connexion…)
# Prod : https://f2m-f1yb.vercel.app — à définir aussi dans Vercel → Settings → Environment Variables
NEXT_PUBLIC_APP_URL=https://f2m-f1yb.vercel.app
