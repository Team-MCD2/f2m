# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/connexion
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/admin
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/admin

# Supabase — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Storage Supabase — créer le bucket "candidat-documents" (public) dans le dashboard
SUPABASE_STORAGE_BUCKET=candidat-documents

# Cloudinary (optionnel — images et non-PDF ; les PDF passent par Supabase)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Emails de relance (https://resend.com) — SDK resend
RESEND_API_KEY=re_...
# En test : onboarding@resend.dev | En prod : domaine vérifié dans Resend
RESEND_FROM_EMAIL=onboarding@resend.dev
